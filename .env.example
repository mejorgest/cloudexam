# Optional bootstrap values. The app prefers data/secrets.json (managed via the
# in-app Configuración screen) and only reads this file if those values are
# missing. Safe to leave empty — the UI will prompt for them on first run.

OPENAI_API_KEY=
GEMINI_API_KEY=

# Postgres (only needed by RAG / pgvector tools — leave blank if unused)
DB_HOST=
DB_PORT=
DB_USER=
DB_PWD=
DB_NAME=
