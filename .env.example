# Optional bootstrap values. The app prefers data/secrets.json (managed via the
# in-app Configuración screen) and only reads this file if those values are
# missing. Safe to leave empty — the UI will prompt for them on first run.
# See README.md for instructions on how to obtain each key.

# ------ LLM ------
# OpenAI: required for the chat agent. Without this, the backend starts but
# the agent is not initialised and the chat does not respond.
OPENAI_API_KEY=

# Gemini: used by textractor_robust.py to extract questions from exam PDFs
# (endpoint /api/exams/extract-from-pdf). Optional if you don't upload PDFs.
GEMINI_API_KEY=

# ------ Postgres + pgvector ------
# Optional. Only needed if you upload exam PDFs or medical images
# (the embeddings are stored in pgvector). Chat and exam analysis work
# without a database.
DB_HOST=
DB_PORT=
DB_USER=
DB_PWD=
DB_NAME=

# ------ Google Custom Search ------
# Optional. Only needed if you want the agent to use the buscar_en_google tool.
# Both values are required when enabling Google search.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
